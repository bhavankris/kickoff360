# Copy to apps/mobile/.env and fill in real values. EXPO_PUBLIC_* vars are inlined
# into the client bundle at build time. These are NOT secrets — the Firebase Web
# config and Google web client id are safe to ship in a client app.
#
# Firebase: Console -> Project settings -> Your apps -> Web app -> SDK config.
EXPO_PUBLIC_FIREBASE_API_KEY=REPLACE_ME
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=REPLACE_ME.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=REPLACE_ME
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=REPLACE_ME.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
EXPO_PUBLIC_FIREBASE_APP_ID=REPLACE_ME

# Google Cloud -> APIs & Services -> Credentials -> OAuth 2.0 -> Web client id.
# Native Google Sign-In sends this as webClientId.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com

# iOS ONLY: the iOS OAuth client id. From the Firebase iOS app's GoogleService-Info.plist
# (CLIENT_ID), or Google Cloud -> Credentials -> the iOS OAuth client. Passed to
# configure() as iosClientId. The matching iosUrlScheme (REVERSED_CLIENT_ID) goes in app.json.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com

# Local backend: set to 1 to point Auth + Firestore at the emulator suite
# (firebase emulators:start). Use your machine's LAN IP for a physical device.
EXPO_PUBLIC_USE_FIREBASE_EMULATOR=0
EXPO_PUBLIC_EMULATOR_HOST=localhost

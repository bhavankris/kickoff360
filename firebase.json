{
  "functions": [
    {
      "source": "packages/functions/.deploy",
      "codebase": "default",
      "runtime": "nodejs22",
      "predeploy": [
        "pnpm --filter @repo/functions build"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "*.log",
        ".secret.local"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  },
  "hosting": {
    "public": "y",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
